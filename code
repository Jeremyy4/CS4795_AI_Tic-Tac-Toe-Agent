import matplotlib.pyplot as plt
import matplotlib.dates as mdates
from datetime import datetime

tasks = [
    {"Task": "Proposal writing + submission",               "Time": "Mar 1 – Mar 5",  "Hours": 10},
    {"Task": "Proposal presentation prep + present",        "Time": "Mar 6 – Mar 12", "Hours": 5},
    {"Task": "Build game environment + pattern features",   "Time": "Mar 13 – Mar 18","Hours": 10},
    {"Task": "Implement BFS/DFS/DLS/IDS + integrate",       "Time": "Mar 19 – Mar 24","Hours": 7},
    {"Task": "Final result: experiments + presentation",    "Time": "Mar 25 – Mar 26","Hours": 5},
    {"Task": "Write paper + bibliography + final submit",   "Time": "Mar 27 – Apr 10","Hours": 10},
]

YEAR = 2026


MONTH_MAP = {
    "Jan": 1, "Feb": 2, "Mar": 3, "Apr": 4, "May": 5, "Jun": 6,
    "Jul": 7, "Aug": 8, "Sep": 9, "Oct": 10, "Nov": 11, "Dec": 12
}

def parse_date_token(token: str) -> datetime:
    parts = token.strip().split()
    mon = MONTH_MAP[parts[0]]
    day = int(parts[1])
    return datetime(YEAR, mon, day)

def parse_range(range_str: str):
    s = range_str.replace("-", "–")
    left, right = [x.strip() for x in s.split("–")]
    return parse_date_token(left), parse_date_token(right)

for t in tasks:
    t["Start"], t["End"] = parse_range(t["Time"])


fig, ax = plt.subplots(figsize=(16, 7))
bar_height = 0.6

tasks_plot = list(reversed(tasks))

for i, t in enumerate(tasks_plot):
    start = mdates.date2num(t["Start"])
    duration_days = (t["End"] - t["Start"]).days + 1  

    ax.barh(i, duration_days, left=start, height=bar_height, align="center")
    ax.text(start + duration_days + 0.1, i, f'{t["Hours"]}h', va="center", fontsize=10)

ax.set_yticks(range(len(tasks_plot)))
ax.set_yticklabels([t["Task"] for t in tasks_plot], fontsize=11)

ax.xaxis.set_major_locator(mdates.WeekdayLocator(interval=1))
ax.xaxis.set_major_formatter(mdates.DateFormatter("%b %d"))
plt.setp(ax.get_xticklabels(), rotation=45, ha="right", fontsize=11)

ax.grid(True, axis="x", linestyle="--", alpha=0.5)
ax.set_xlabel("Date", fontsize=12)
ax.set_title("Project Timeline — Gantt Chart (Simplified)", fontsize=16)

plt.tight_layout()
plt.show()
